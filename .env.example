# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# ── Cloudflare R2 (object storage) ───────────────────────────────────────────
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR

# ── Shiprocket ────────────────────────────────────────────────────────────────
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in/v1/external

# ── SMTP (email delivery) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=Ecommerce Store

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-storefront.netlify.app
ADMIN_URL=https://your-admin.netlify.app
CORS_ALLOWED_ORIGINS=https://your-storefront.netlify.app,https://your-admin.netlify.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=50MB
LOG_SQL=OFF
